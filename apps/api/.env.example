# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/directmate

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Meta / Instagram
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_APP_ID=
META_APP_SECRET_OAUTH=

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Internal
INTERNAL_API_KEY=change-me-internal-key

# CLIP image embeddings (Replicate API — see image-embedding.service.ts)
CLIP_ENABLED=false
REPLICATE_API_TOKEN=
# Pinned krthr/clip-embeddings version (CLIP ViT-B/32, 512-dim).
# Bump deliberately — a new variant could shift output space.
REPLICATE_CLIP_MODEL_VERSION=1c0371070cb827ec3c7f2f28adcdde54b50dcd239aa6faea0bc98b174ef03fb4
