# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/directmate

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Meta / Instagram
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_APP_ID=
