# ─── Domain ──────────────────────────────────────────────
DOMAIN=directmate.yourdomain.com

# ─── Database ────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=directmate

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_random_64_char_string
JWT_EXPIRES_IN=7d

# ─── Meta / Instagram ───────────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_WEBHOOK_VERIFY_TOKEN=directmate_verify_a3f7b9c2e1d4
INSTAGRAM_OAUTH_REDIRECT_URI=https://directmate.yourdomain.com/auth/instagram/callback

# ─── Encryption ──────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_64_hex_chars

# ─── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4.1

# ─── Internal API (n8n ↔ backend) ───────────────────────
INTERNAL_API_KEY=CHANGE_ME_random_string

# ─── n8n ─────────────────────────────────────────────────
N8N_DB=n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_n8n_password
N8N_ORDER_SYNC_WEBHOOK_URL=https://directmate.yourdomain.com/n8n/webhook/shopify-order-sync

# ─── Telegram ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret
TELEGRAM_BOT_USERNAME=DirectMateBot

# ─── FTP (Torgsoft sync, single-tenant: luxespace) ───────
# Public IPv4 the FTP server announces to clients for passive-mode data
# connections. MUST be reachable from external FTP clients (the Torgsoft
# operator's POS). Find with: curl -4 ifconfig.io
FTP_PASV_ADDRESS=
# Generated by scripts/ftp/generate-credentials.sh — do not set manually.
FTP_LUXESPACE_PASS=
